DATABASE_URL=postgresql+asyncpg://gvevent:your_strong_password@localhost:5432/guestvision
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=replace_with_32_plus_random_characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_MODEL_DIR=./models
FACE_THRESHOLD=0.45
FACE_QUALITY_MIN=0.5
LOAD_FACE_ENGINE_ON_STARTUP=true
STRICT_AI_STARTUP=false
INIT_DB_ON_STARTUP=true

STORAGE_MODE=local
LOCAL_STORAGE_PATH=./uploads
AWS_BUCKET=
AWS_REGION=ap-south-1

BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
DEVICE_SECRET=replace_with_shared_iot_device_token
